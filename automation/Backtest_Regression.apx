<?xml version="1.0" encoding="ISO-8859-1"?>
<AmiBroker-Analysis CompactMode="0">
<General>
<FormatVersion>1</FormatVersion>
<Symbol>META</Symbol>
<FormulaPath>G:\OneDrive\01_TRADING\AFL_DEV\VWAP_01\VWAP_01_STRATEGY.afl</FormulaPath>
<FormulaContent>// ============================================================================\r\n// STRATEGY — VWAP Trend Trading (Zarattini &amp; Aziz 2023)\r\n// ----------------------------------------------------------------------------\r\n// Paper-faithful day-trading system over SharedAFL plumbing:\r\n//   long when prior 1-min close is above RTH VWAP, short when below;\r\n//   flatten at RTH end; constant dollar position value (not compounding %).\r\n//\r\n// Exit modes (Param "Use RTH VWAP Exit"):\r\n//   Yes — ORB/SharedAFL phased RTH VWAP trailing stop (ATR offsets, ±1/2 SD\r\n//         phases, ratchet-only). Flat after trail; re-enter on next side streak.\r\n//   No  — paper always-in VWAP close flip (reverse on opposite close).\r\n//\r\n// Canonical libs:\r\n//   g:\\OneDrive\\01_TRADING\\AFL_DEV\\SharedAFL\\lib\\\r\n//\r\n// Regression:\r\n//   1. python tools/make_regression_apx.py VWAP_01_STRATEGY.afl automation/Backtest_Regression.apx\r\n//   2. python tools/make_cleanup_apx.py VWTT\r\n//   3. python tools/run_regression.py results/Latest.csv automation/Backtest_Regression.apx\r\n//\r\n// Commission: set Analysis commission to $0.0005/share to match the paper\r\n// (AFL cannot fully own broker commission tables).\r\n// ============================================================================\r\n\r\nStrategyCode = "VWTT";\r\n\r\n// ============================================================================\r\n// PARAMETERS — the minimum set the libs require\r\n// All session times are Eastern (EST/EDT as stamped in the AmiBroker database).\r\n// RTH 9:30–16:00 EST.\r\n// ============================================================================\r\n_SECTION_BEGIN("Session Times &amp; Time Filters");\r\nRthStartHour        = Param("RTH Start Hour", 9, 0, 23, 1);\r\nRthStartMin         = Param("RTH Start Min", 30, 0, 59, 1);\r\nRthEndHour          = Param("RTH End Hour", 16, 0, 23, 1);\r\nRthEndMin           = Param("RTH End Min", 0, 0, 59, 1);\r\nUseTimeFilter       = ParamToggle("Use Time Filter", "No|Yes", 0);\r\nTimeFilterStartHour = Param("Time Filter Start Hour", 9, 0, 23, 1);\r\nTimeFilterStartMin  = Param("Time Filter Start Min", 30, 0, 59, 1);\r\nTimeFilterEndHour   = Param("Time Filter End Hour", 12, 0, 23, 1);\r\nTimeFilterEndMin    = Param("Time Filter End Min", 30, 0, 59, 1);\r\n\r\n// Paper §5 midday cost-efficiency idea (12:00–15:00 EST).\r\n// Default Off so main backtest matches published results.\r\nUseMiddayBlackout   = ParamToggle("Midday Blackout 12-3 EST", "No|Yes", 0);\r\nUseBlackout         = UseMiddayBlackout;\r\nBlackoutStartHour   = Param("Blackout Start Hour", 12, 0, 23, 1);\r\nBlackoutStartMin    = Param("Blackout Start Min", 0, 0, 59, 1);\r\nBlackoutEndHour     = Param("Blackout End Hour", 15, 0, 23, 1);\r\nBlackoutEndMin      = Param("Blackout End Min", 0, 0, 59, 1);\r\n\r\nExitAtRthEnd        = ParamToggle("Exit At Set Time", "No|Yes", 1);\r\nExitHour            = Param("Exit Hour", 16, 0, 23, 1);\r\nExitMinute          = Param("Exit Minute", 0, 0, 59, 1);\r\n_SECTION_END();\r\n\r\n_SECTION_BEGIN("Position Sizing");\r\n// Constant dollar notional per trade (does not compound with equity).\r\nFixedPositionValue  = Param("Fixed Position Value ($)", 25000, 1000, 10000000, 1000);\r\nUsePercentRisk      = ParamToggle("Use % Risk Sizing", "No|Yes", 0);\r\nRiskPercent         = Param("Risk % per Trade", 1.0, 0.1, 10.0, 0.1);\r\nMaxShares           = Param("Max Shares", 1000000, 1, 10000000, 1);\r\nFixedShares         = Param("Fixed Shares", 100, 1, 100000, 1);\r\nOverrideBalance     = Param("Override Account Balance ($0=actual)", 0, 0, 10000000, 1000);\r\nMaxPctOfEquity      = Param("Max Position % of Equity", 100, 10, 100, 5);\r\nSkipIfRiskExceeded  = ParamToggle("Skip if 1 Share &gt; Risk%", "No|Yes", 0);\r\n#include "g:\\OneDrive\\01_TRADING\\AFL_DEV\\SharedAFL\\lib\\AFL_Lib_PositionSizing.afl"\r\n_SECTION_END();\r\n\r\n_SECTION_BEGIN("Stops, Targets &amp; VWAP Exit");\r\n// Phased RTH VWAP trail — same rules as ORB (SharedAFL VwapBands + ATR offsets).\r\nAtrPeriod            = Param("ATR Period", 14, 5, 50, 1);\r\nAtrStopMult          = Param("ATR Stop Multiplier", 1.5, 0.5, 5.0, 0.1);\r\nUseRthVwapExit       = ParamToggle("Use RTH VWAP Exit", "No|Yes", 1);\r\nUseAtrTrailing       = ParamToggle("ATR Trail Offsets", "No|Yes", 1);\r\nAtrTrailP1Factor     = Param("ATR Trail P1 Factor", 2.5, 0.1, 5.0, 0.05);\r\nAtrTrailP2Factor     = Param("ATR Trail P2 Factor", 2.0, 0.1, 5.0, 0.05);\r\nAtrTrailP2TFactor    = Param("ATR Trail P2T Factor", 0.75, 0.1, 5.0, 0.05);\r\nPhase2ActBars        = Param("Phase2 Activation Bars", 2, 1, 5, 1);\r\nPhase2TightBars      = Param("Phase2 Tight Bars", 2, 1, 5, 1);\r\nEnablePhaseReversal  = ParamToggle("Phase Reversal", "No|Yes", 1);\r\nPhaseReversalBars    = Param("Phase Reversal Bars", 1, 1, 5, 1);\r\n_SECTION_END();\r\n\r\n_SECTION_BEGIN("Universe &amp; Context");\r\nAdvLookback         = Param("ADV Lookback (days)", 20, 5, 252, 1);\r\nEnableUniverseRank  = ParamToggle("Universe Rank Gate (backtest)", "No|Yes", 0);\r\nUniverseTopN        = Param("Universe Top-N (rank cut)", 15, 1, 200, 1);\r\n_SECTION_END();\r\n\r\n_SECTION_BEGIN("Display");\r\nShowRthVwapBands    = ParamToggle("Show RTH VWAP + SD Bands", "No|Yes", 1);\r\nShowRthVwap2SD      = ParamToggle("Show ±2 SD Bands", "No|Yes", 1);\r\nShowStopLine        = ParamToggle("Show Active Stop Line", "No|Yes", 1);\r\n_SECTION_END();\r\n\r\n// ============================================================================\r\n// PLUMBING — session time, VWAP bands, daily context\r\n// ============================================================================\r\n#include "g:\\OneDrive\\01_TRADING\\AFL_DEV\\SharedAFL\\lib\\AFL_Lib_SessionTime.afl"\r\n#include "g:\\OneDrive\\01_TRADING\\AFL_DEV\\SharedAFL\\lib\\AFL_Lib_VwapBands.afl"\r\n#include "g:\\OneDrive\\01_TRADING\\AFL_DEV\\SharedAFL\\lib\\AFL_Lib_DailyContext.afl"\r\n\r\nDailyATR = ATR(AtrPeriod);\r\n\r\n// ============================================================================\r\n// BACKTEST OPTIONS — paper defaults (APX InitialEquity can override)\r\n// ============================================================================\r\n// InitialEquity should stay above Fixed Position Value so trades are never\r\n// skipped for lack of funds when sizing is constant dollars.\r\nSetOption("InitialEquity", 100000);\r\nSetOption("AllowSameBarExit", True);\r\nSetOption("ReverseSignalForcesExit", True);\r\nSetOption("MaxOpenPositions", 1);\r\nSetTradeDelays(0, 0, 0, 0);\r\n\r\n// ============================================================================\r\n// SIGNAL — VWAP Trend Trading (+ optional RTH VWAP trail exit)\r\n// ----------------------------------------------------------------------------\r\n// Wait out first RTH bar (RthOpen). Side from prior bar close vs RTH VWAP;\r\n// fill at this bar's Open. No overnight.\r\n// ============================================================================\r\nprevVwapOk = NOT IsNull(Ref(RthVwap, -1));\r\nprevAbove  = prevVwapOk AND Ref(C &gt; RthVwap, -1);\r\nprevBelow  = prevVwapOk AND Ref(C &lt; RthVwap, -1);\r\n\r\nCanTrade = IsRTH AND NOT RthOpen AND prevVwapOk\r\n           AND WithinTimeFilter AND NOT InBlackout;\r\n\r\nQualityScore = log(1 + AvgDailyRthVol);\r\n\r\nUniScore     = QualityScore;\r\nUniLockBar   = RthOpen;\r\nUniSnapValid = IsRTH;\r\nUniCandidate = AvgDailyRthVol &gt; 0;\r\n#include "g:\\OneDrive\\01_TRADING\\AFL_DEV\\SharedAFL\\lib\\AFL_Lib_UniverseRank.afl"\r\n\r\nrankOK = NOT UniRankGateOn OR (UniRanksReady AND UniRank &lt;= UniverseTopN);\r\n\r\nwantLong  = CanTrade AND prevAbove AND NOT PastExitTime AND NOT LastRthBar AND rankOK;\r\nwantShort = CanTrade AND prevBelow AND NOT PastExitTime AND NOT LastRthBar AND rankOK;\r\n\r\n// Trail mode: enter only on first bar of a side streak (no immediate re-entry\r\n// after a trail stop while still on the same side). Paper flip: always-in.\r\nlongEntrySig  = IIf(UseRthVwapExit, wantLong  AND NOT Ref(wantLong,  -1), wantLong);\r\nshortEntrySig = IIf(UseRthVwapExit, wantShort AND NOT Ref(wantShort, -1), wantShort);\r\n\r\nBuy = Sell = Short = Cover = 0;\r\nBuyPrice = SellPrice = ShortPrice = CoverPrice = Open;\r\nActiveStopArr = Null;\r\n\r\nin_trade = 0;\r\ntrade_dir = 0;\r\ntrail_stop = 0;\r\nstop_price = 0;\r\nvwap_phase = 0;\r\nconsec_1sd = 0;\r\nconsec_2sd = 0;\r\nconsec_reversal = 0;\r\nentered_favorable = 0;\r\n\r\nfor (i = 0; i &lt; BarCount; i++)\r\n{\r\n    exit_reason = "";\r\n\r\n    // --- manage open trade ---\r\n    if (in_trade)\r\n    {\r\n        if (PastExitTime[i] OR LastRthBar[i])\r\n        {\r\n            exit_reason = "EOD";\r\n            if (trade_dir == 1)\r\n            {\r\n                Sell[i] = 1;\r\n                SellPrice[i] = C[i];\r\n            }\r\n            else\r\n            {\r\n                Cover[i] = 1;\r\n                CoverPrice[i] = C[i];\r\n            }\r\n        }\r\n        else if (UseRthVwapExit AND NOT IsNull(RthVwap[i]) AND RthVwap[i] &gt; 0)\r\n        {\r\n            atrNow = DailyATR[i];\r\n            p1Off  = IIf(UseAtrTrailing AND atrNow &gt; 0, atrNow * AtrTrailP1Factor, 4.0);\r\n            p2Off  = IIf(UseAtrTrailing AND atrNow &gt; 0, atrNow * AtrTrailP2Factor, 3.0);\r\n            p2tOff = IIf(UseAtrTrailing AND atrNow &gt; 0, atrNow * AtrTrailP2TFactor, 2.0);\r\n            prevClose = C[Max(i - 1, 0)];\r\n\r\n            if (trade_dir == 1)\r\n            {\r\n                // Initial ATR protective stop\r\n                if (stop_price &gt; 0 AND L[i] &lt;= stop_price)\r\n                {\r\n                    exit_reason = "Stop Loss";\r\n                    Sell[i] = 1;\r\n                    SellPrice[i] = stop_price;\r\n                }\r\n\r\n                if (exit_reason == "")\r\n                {\r\n                    // Phase transitions (long) — ORB / SharedAFL trail\r\n                    if (vwap_phase == 0)\r\n                    {\r\n                        if (entered_favorable)\r\n                        {\r\n                            if (prevClose &gt; RthVwapU1SD[i])\r\n                            {\r\n                                consec_1sd = consec_1sd + 1;\r\n                                if (consec_1sd &gt;= Phase2ActBars)\r\n                                {\r\n                                    vwap_phase = 2;\r\n                                    consec_1sd = 0;\r\n                                }\r\n                            }\r\n                            else\r\n                                consec_1sd = 0;\r\n                        }\r\n                        else\r\n                        {\r\n                            if (prevClose &gt; RthVwap[i])\r\n                                vwap_phase = 1;\r\n                        }\r\n                    }\r\n                    if (vwap_phase == 1)\r\n                    {\r\n                        if (prevClose &gt; RthVwapU1SD[i])\r\n                        {\r\n                            consec_1sd = consec_1sd + 1;\r\n                            if (consec_1sd &gt;= Phase2ActBars)\r\n                            {\r\n                                vwap_phase = 2;\r\n                                consec_1sd = 0;\r\n                            }\r\n                        }\r\n                        else\r\n                            consec_1sd = 0;\r\n                    }\r\n                    if (vwap_phase == 2)\r\n                    {\r\n                        if (prevClose &gt; RthVwapU2SD[i])\r\n                        {\r\n                            consec_2sd = consec_2sd + 1;\r\n                            consec_reversal = 0;\r\n                            if (consec_2sd &gt;= Phase2TightBars)\r\n                                vwap_phase = 3;\r\n                        }\r\n                        else\r\n                            consec_2sd = 0;\r\n                    }\r\n                    if (vwap_phase == 3 AND EnablePhaseReversal)\r\n                    {\r\n                        if (prevClose &lt;= RthVwapU2SD[i])\r\n                        {\r\n                            consec_reversal = consec_reversal + 1;\r\n                            if (consec_reversal &gt;= PhaseReversalBars)\r\n                            {\r\n                                vwap_phase = 2;\r\n                                consec_2sd = 0;\r\n                                consec_reversal = 0;\r\n                            }\r\n                        }\r\n                        else\r\n                            consec_reversal = 0;\r\n                    }\r\n\r\n                    newTrail = 0;\r\n                    if (vwap_phase == 1)      newTrail = RthVwap[i] - p1Off;\r\n                    else if (vwap_phase == 2) newTrail = RthVwapU1SD[i] - p2Off;\r\n                    else if (vwap_phase == 3) newTrail = RthVwapU2SD[i] - p2tOff;\r\n\r\n                    if (newTrail &gt; 0)\r\n                    {\r\n                        if (trail_stop == 0 OR newTrail &gt; trail_stop)\r\n                            trail_stop = newTrail;\r\n                    }\r\n\r\n                    if (trail_stop &gt; 0 AND L[i] &lt;= trail_stop)\r\n                    {\r\n                        exit_reason = "VWAP Trail";\r\n                        Sell[i] = 1;\r\n                        SellPrice[i] = trail_stop;\r\n                    }\r\n                }\r\n            }\r\n            else if (trade_dir == -1)\r\n            {\r\n                if (stop_price &gt; 0 AND H[i] &gt;= stop_price)\r\n                {\r\n                    exit_reason = "Stop Loss";\r\n                    Cover[i] = 1;\r\n                    CoverPrice[i] = stop_price;\r\n                }\r\n\r\n                if (exit_reason == "")\r\n                {\r\n                    if (vwap_phase == 0)\r\n                    {\r\n                        if (entered_favorable)\r\n                        {\r\n                            if (prevClose &lt; RthVwapL1SD[i])\r\n                            {\r\n                                consec_1sd = consec_1sd + 1;\r\n                                if (consec_1sd &gt;= Phase2ActBars)\r\n                                {\r\n                                    vwap_phase = 2;\r\n                                    consec_1sd = 0;\r\n                                }\r\n                            }\r\n                            else\r\n                                consec_1sd = 0;\r\n                        }\r\n                        else\r\n                        {\r\n                            if (prevClose &lt; RthVwap[i])\r\n                                vwap_phase = 1;\r\n                        }\r\n                    }\r\n                    if (vwap_phase == 1)\r\n                    {\r\n                        if (prevClose &lt; RthVwapL1SD[i])\r\n                        {\r\n                            consec_1sd = consec_1sd + 1;\r\n                            if (consec_1sd &gt;= Phase2ActBars)\r\n                            {\r\n                                vwap_phase = 2;\r\n                                consec_1sd = 0;\r\n                            }\r\n                        }\r\n                        else\r\n                            consec_1sd = 0;\r\n                    }\r\n                    if (vwap_phase == 2)\r\n                    {\r\n                        if (prevClose &lt; RthVwapL2SD[i])\r\n                        {\r\n                            consec_2sd = consec_2sd + 1;\r\n                            consec_reversal = 0;\r\n                            if (consec_2sd &gt;= Phase2TightBars)\r\n                                vwap_phase = 3;\r\n                        }\r\n                        else\r\n                            consec_2sd = 0;\r\n                    }\r\n                    if (vwap_phase == 3 AND EnablePhaseReversal)\r\n                    {\r\n                        if (prevClose &gt;= RthVwapL2SD[i])\r\n                        {\r\n                            consec_reversal = consec_reversal + 1;\r\n                            if (consec_reversal &gt;= PhaseReversalBars)\r\n                            {\r\n                                vwap_phase = 2;\r\n                                consec_2sd = 0;\r\n                                consec_reversal = 0;\r\n                            }\r\n                        }\r\n                        else\r\n                            consec_reversal = 0;\r\n                    }\r\n\r\n                    newTrail = 0;\r\n                    if (vwap_phase == 1)      newTrail = RthVwap[i] + p1Off;\r\n                    else if (vwap_phase == 2) newTrail = RthVwapL1SD[i] + p2Off;\r\n                    else if (vwap_phase == 3) newTrail = RthVwapL2SD[i] + p2tOff;\r\n\r\n                    if (newTrail &gt; 0)\r\n                    {\r\n                        if (trail_stop == 0 OR newTrail &lt; trail_stop)\r\n                            trail_stop = newTrail;\r\n                    }\r\n\r\n                    if (trail_stop &gt; 0 AND H[i] &gt;= trail_stop)\r\n                    {\r\n                        exit_reason = "VWAP Trail";\r\n                        Cover[i] = 1;\r\n                        CoverPrice[i] = trail_stop;\r\n                    }\r\n                }\r\n            }\r\n        }\r\n        else if (NOT UseRthVwapExit)\r\n        {\r\n            // Paper flip: reverse on opposite VWAP close\r\n            if (trade_dir == 1 AND prevBelow[i] AND CanTrade[i])\r\n            {\r\n                exit_reason = "VWAP Flip";\r\n                Sell[i] = 1;\r\n                SellPrice[i] = O[i];\r\n            }\r\n            else if (trade_dir == -1 AND prevAbove[i] AND CanTrade[i])\r\n            {\r\n                exit_reason = "VWAP Flip";\r\n                Cover[i] = 1;\r\n                CoverPrice[i] = O[i];\r\n            }\r\n        }\r\n\r\n        if (exit_reason != "")\r\n        {\r\n            in_trade = 0;\r\n            trade_dir = 0;\r\n            trail_stop = 0;\r\n            stop_price = 0;\r\n            vwap_phase = 0;\r\n            consec_1sd = 0;\r\n            consec_2sd = 0;\r\n            consec_reversal = 0;\r\n            entered_favorable = 0;\r\n        }\r\n        else\r\n        {\r\n            if (trail_stop &gt; 0)\r\n                ActiveStopArr[i] = trail_stop;\r\n            else if (stop_price &gt; 0)\r\n                ActiveStopArr[i] = stop_price;\r\n        }\r\n    }\r\n\r\n    // --- entries (and paper same-bar reverse) ---\r\n    if (NOT in_trade)\r\n    {\r\n        if (longEntrySig[i])\r\n        {\r\n            entryP = O[i];\r\n            atrNow = DailyATR[i];\r\n            stopDist = IIf(atrNow &gt; 0, atrNow * AtrStopMult, 0.01 * entryP);\r\n\r\n            Buy[i] = 1;\r\n            BuyPrice[i] = entryP;\r\n            stop_price = entryP - stopDist;\r\n            trail_stop = stop_price;\r\n            vwap_phase = 0;\r\n            consec_1sd = 0;\r\n            consec_2sd = 0;\r\n            consec_reversal = 0;\r\n            entered_favorable = (!IsNull(RthVwap[i]) AND RthVwap[i] &gt; 0 AND entryP &gt; RthVwap[i]);\r\n            in_trade = 1;\r\n            trade_dir = 1;\r\n            ActiveStopArr[i] = trail_stop;\r\n        }\r\n        else if (shortEntrySig[i])\r\n        {\r\n            entryP = O[i];\r\n            atrNow = DailyATR[i];\r\n            stopDist = IIf(atrNow &gt; 0, atrNow * AtrStopMult, 0.01 * entryP);\r\n\r\n            Short[i] = 1;\r\n            ShortPrice[i] = entryP;\r\n            stop_price = entryP + stopDist;\r\n            trail_stop = stop_price;\r\n            vwap_phase = 0;\r\n            consec_1sd = 0;\r\n            consec_2sd = 0;\r\n            consec_reversal = 0;\r\n            entered_favorable = (!IsNull(RthVwap[i]) AND RthVwap[i] &gt; 0 AND entryP &lt; RthVwap[i]);\r\n            in_trade = 1;\r\n            trade_dir = -1;\r\n            ActiveStopArr[i] = trail_stop;\r\n        }\r\n    }\r\n}\r\n\r\n// Same dollar notional every trade (shares = FixedPositionValue / entry price).\r\nSetPositionSize(FixedPositionValue, spsValue);\r\n\r\n// ============================================================================\r\n// DISPLAY\r\n// ============================================================================\r\nPlot(C, "Close", colorDefault, styleCandle);\r\n\r\nif (ShowRthVwapBands)\r\n{\r\n    Plot(RthVwap, "RTH VWAP", colorYellow, styleLine | styleNoRescale);\r\n    Plot(RthVwapU1SD, "RTH +1 SD", colorAqua, styleLine | styleNoRescale | styleDashed);\r\n    Plot(RthVwapL1SD, "RTH -1 SD", colorAqua, styleLine | styleNoRescale | styleDashed);\r\n    if (ShowRthVwap2SD)\r\n    {\r\n        Plot(RthVwapU2SD, "RTH +2 SD", colorBlue, styleLine | styleNoRescale | styleDots);\r\n        Plot(RthVwapL2SD, "RTH -2 SD", colorBlue, styleLine | styleNoRescale | styleDots);\r\n    }\r\n}\r\nelse\r\n{\r\n    Plot(RthVwap, "RTH VWAP", colorYellow, styleLine | styleNoRescale);\r\n}\r\n\r\nif (ShowStopLine)\r\n    Plot(ActiveStopArr, "Active Stop", colorOrange, styleLine | styleNoRescale | styleThick);\r\n\r\nPlotShapes(IIf(Buy,   shapeUpArrow,   shapeNone), colorGreen, 0, L, -12);\r\nPlotShapes(IIf(Short, shapeDownArrow, shapeNone), colorRed,   0, H, -12);\r\nPlotShapes(IIf(Sell,  shapeSmallCircle, shapeNone), colorOrange, 0, H, 12);\r\nPlotShapes(IIf(Cover, shapeSmallCircle, shapeNone), colorOrange, 0, L, -12);\r\n\r\n_N(Title = StrFormat("{{NAME}} " + StrategyCode + " VWAP Trend {{INTERVAL}} {{DATE}} C=%g VWAP=%g | Exit=%s",\r\n    C, Nz(RthVwap), WriteIf(UseRthVwapExit, "VWAP Trail", "Paper Flip")));\r\n</FormulaContent>
<ApplyTo>2</ApplyTo>
<RangeType>0</RangeType>
<RangeAmount>1</RangeAmount>
<FromDate>2016-01-01 00:00:00</FromDate>
<ToDate>2026-07-13</ToDate>
<OnSelectAction>7</OnSelectAction>
<RunEvery>0</RunEvery>
<RunEveryInterval>5min</RunEveryInterval>
<IncludeFilter>
<ExcludeMode>0</ExcludeMode>
<OrSelection>1</OrSelection>
<Favourite>0</Favourite>
<Index>0</Index>
<Type0>0</Type0>
<Category0>-1</Category0>
<Type1>1</Type1>
<Category1>-1</Category1>
<Type2>2</Type2>
<Category2>-1</Category2>
<Type3>3</Type3>
<Category3>-1</Category3>
<Type4>4</Type4>
<Category4>0</Category4>
<Type5>5</Type5>
<Category5>-1</Category5>
<Type6>6</Type6>
<Category6>-1</Category6>
</IncludeFilter>
<ExcludeFilter>
<ExcludeMode>1</ExcludeMode>
<OrSelection>0</OrSelection>
<Favourite>0</Favourite>
<Index>0</Index>
<Type0>0</Type0>
<Category0>-1</Category0>
<Type1>1</Type1>
<Category1>-1</Category1>
<Type2>2</Type2>
<Category2>-1</Category2>
<Type3>3</Type3>
<Category3>-1</Category3>
<Type4>4</Type4>
<Category4>-1</Category4>
<Type5>5</Type5>
<Category5>-1</Category5>
<Type6>6</Type6>
<Category6>-1</Category6>
</ExcludeFilter>
</General>
<BacktestSettings>
<InitialEquity>100000</InitialEquity>
<TradeFlags>3</TradeFlags>
<MaxLossStopMode>0</MaxLossStopMode>
<MaxLossStopValue>0</MaxLossStopValue>
<MaxLossStopAtStop>0</MaxLossStopAtStop>
<ProfitStopMode>0</ProfitStopMode>
<ProfitStopValue>0</ProfitStopValue>
<ProfitStopAtStop>0</ProfitStopAtStop>
<TrailingStopMode>0</TrailingStopMode>
<TrailingStopPeriods>0</TrailingStopPeriods>
<TrailingStopValue>0</TrailingStopValue>
<TrailingStopAtStop>0</TrailingStopAtStop>
<CommissionMode>0</CommissionMode>
<CommissionValue>0.0035</CommissionValue>
<BuyPriceField>0</BuyPriceField>
<BuyDelay>0</BuyDelay>
<SellPriceField>0</SellPriceField>
<SellDelay>0</SellDelay>
<ShortPriceField>0</ShortPriceField>
<ShortDelay>0</ShortDelay>
